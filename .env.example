# Choose your LLM Provider: 'gemini' or 'deepseek'
LLM_PROVIDER="gemini"

# Gemini Configuration (Get one at https://aistudio.google.com/)
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-3.5-flash"

# DeepSeek Configuration (Get one at https://platform.deepseek.com/)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_MODEL="deepseek-v4-pro"

# Optional: Path to the SQLite database
# DB_PATH="rss_memory.db"

# Optional: Output directory for the generated RSS feeds
# OUTPUT_DIR="output_feeds"
